/* Text wrapping */
.text-wrap {
    white-space: normal!important;
}
.text-nowrap {
    white-space: nowrap!important;
}

/* Font Size */
.fs-1 {
    font-size: 40px;
}
.fs-2 {
    font-size: 32px;
}
.fs-3 {
    font-size: 28px;
}
.fs-4 {
    font-size: 24px;
}
.fs-5 {
    font-size: 20px;
}
.fs-6 {
    font-size: 16px;
}

/* Font Style */
.fst-bold {
    -unity-font-style: bold;
}
.fst-italic {
    -unity-font-style: italic;
}
.fst-normal {
    -unity-font-style: normal;
}

/* Pointer Detection */
.pointer-detection {
    --pointer-detection: rect;
}
.pointer-ignore {
    --pointer-detection: ignore;
}
.pointer-none {
    --pointer-detection: force-ignore;
}