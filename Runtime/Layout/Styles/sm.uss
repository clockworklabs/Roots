.g-sm-0 {
    --rs-gutter-x: 0px;
    --rs-half-gutter-x: 0px;
    --rs-neg-gutter-x: 0px;
    --rs-gutter-y: 0px;
    --rs-half-gutter-y: 0px;
    --rs-neg-gutter-y: 0px;
}
.g-sm-1 {
    --rs-gutter-x: 4px;
    --rs-half-gutter-x: 2px;
    --rs-neg-gutter-x: -4px;
    --rs-gutter-y: 4px;
    --rs-half-gutter-y: 2px;
    --rs-neg-gutter-y: -4px;
}
.g-sm-2 {
