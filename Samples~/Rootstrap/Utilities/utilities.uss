.text-white-50 {
    color: var(--rs-white-50)!important;
}

/* Rounded Corners */
.rounded {
    border-radius: var(--rs-border-radius-2)!important;
}
.rounded-top {
    border-top-left-radius: var(--rs-border-radius-2)!important;
    border-top-right-radius: var(--rs-border-radius-2)!important;
}
