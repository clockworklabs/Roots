.g-lg-0 {
    --rs-gutter-hx: 0;
    --rs-gutter-nhx: 0;
    --rs-gutter-hy: 0;
    --rs-gutter-nhy: 0;
}
.g-lg-1 {
    --rs-gutter-hx: 2px;
    --rs-gutter-nhx: -2px;
    --rs-gutter-hy: 2px;
    --rs-gutter-nhy: -2px;
}
.g-lg-2 {
    --rs-gutter-hx: 4px;
