:root {
    --rs-gutter-x: 24px;
    --rs-gutter-y: 0;
    --rs-half-gutter-x: 12px;
    --rs-half-gutter-y: 0;
    --rs-neg-gutter-x: -24px;
    --rs-neg-gutter-y: 0;
}

.container-fluid {
    width: 100%;
}
.container {
    align-self: center;
    width: 100%;
}
.container-sm {
    align-self: center;
    width: 100%;
}
.container-md {
    align-self: center;
    width: 100%;
}
.container-lg {
    align-self: center;
    width: 100%;
}
.container-xl {
    align-self: center;
    width: 100%;
}
.container-xxl {
    align-self: center;
    width: 100%;
}

.row {
    flex-direction: row;
    flex-wrap: wrap;
    margin-right: var(--rs-neg-gutter-x);
    margin-left: var(--rs-neg-gutter-x);
}
.row>* {
    flex-shrink: 0;
    width: 100%;
    max-width: 100%;
    padding-right: var(--rs-half-gutter-x);
    padding-left: var(--rs-half-gutter-x);
    margin-top: var(--rs-half-gutter-y);
}

.col {
    flex: 1 0 0%;
}

.row-cols-1>* {
    flex: 0 0 auto;
    width: 100%;
}
.row-cols-2>* {
    flex: 0 0 auto;
    width: 50%;
