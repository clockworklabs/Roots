/* Text Alignment */
.text-left {
    -unity-text-align: upper-left!important;
}
.text-right {
    -unity-text-align: upper-right!important;
}
.text-center {
    -unity-text-align: upper-center!important;
}
.text-upper-left {
    -unity-text-align: upper-left!important;
}
.text-upper-right {
    -unity-text-align: upper-right!important;
}
.text-upper-center {
    -unity-text-align: upper-center!important;
}
.text-middle-left {
    -unity-text-align: middle-left!important;
}
.text-middle-right {
    -unity-text-align: middle-right!important;
}
.text-middle-center {
    -unity-text-align: middle-center!important;
}
.text-lower-left {
    -unity-text-align: lower-left!important;
}
.text-lower-right {
    -unity-text-align: lower-right!important;
}
.text-lower-center {
    -unity-text-align: lower-center!important;
}

/* --- Visibility - */
.visible {
    visibility: visible !important;
}
.invisible {
    visibility: hidden !important;
}





/* --- Absolute Fill - */
.absolute-fill {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
}

/* --- Opacity - */
.opacity-0 {
    opacity: 0;
}
.opacity-25 {
    opacity: 0.25;
}
.opacity-50 {
    opacity: 0.5;
}
.opacity-75 {
    opacity: 0.75;
}
.opacity-100 {
    opacity: 1;
}

/* --- Overflow - */
.overflow-hidden {
    overflow: hidden;
}
.overflow-visible {
    overflow: visible;
}

/* --- Position - */
.position-relative {
    position: relative;
}
.position-absolute {
    position: absolute;
}

/* --- Arrange  Elements - */
.top-0 {
    top: 0;
}
.top-50 {
    top: 50%;
}
.top-100 {
    top: 100%;
}
.right-0 {
    right: 0;
}
.right-50 {
    right: 50%;
}
.right-100 {
    right: 100%;
}
.bottom-0 {
    bottom: 0;
}
.bottom-50 {
    bottom: 50%;
}
.bottom-100 {
    bottom: 100%;
}
.left-0 {
    left: 0;
}
.left-50 {
    left: 50%;
}
.left-100 {
    left: 100%;
}
.translate-middle {
    translate: -50% -50% 0;
}
.translate-x {
    translate: -50% 0 0;
}
.translate-y {
    translate: 0 -50% 0;
}


/* --- Sizing - */
.w-0 {
    width: 0;
}
.w-25 {
    width: 25%;
}
.w-50 {
    width: 50%;
}
.w-75 {
    width: 75%;
}
.w-100 {
    width: 100%;
}
.w-auto {
    width: auto;
}
.mw-100 {
    max-width: 100%;
}
.h-0 {
    height: 0;
}
.h-25 {
    height: 25%;
}
.h-50 {
    height: 50%;
}
.h-75 {
    height: 75%;
}
.h-100 {
    height: 100%;
}
.h-auto {
    height: auto;
}
.mh-100 {
    max-height: 100%;
}

