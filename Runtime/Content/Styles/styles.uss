:root {
    --rs-body-color: #adb5bd;
    --rs-heading-color: inherit;
}

.body {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    
    color: var(--rs-body-color);
    font-size: 16px;
}

.h1, .h2, .h3, .h4, .h5, .h6 {
    margin-top: 0;
    margin-bottom: 8px;
    -unity-font-style: bold;
    /*line-height: 1.2;*/
    color: var(--rs-heading-color);
}
.h1 {
    font-size: 40px;
}
.h2 {
    font-size: 32px;
}
.h3 {
    font-size: 28px;
}
.h4 {
    font-size: 24px;
}
.h5 {
    font-size: 20px;
}
.h6 {
    font-size: 16px;
}
.p {
    margin-top: 0;
    margin-bottom: 16px;
}
.small {
    font-size: 14px;
}
.lead {
    font-size: 20px;
    font-weight: 300;
}

Image {
    overflow: hidden;
}

.img-fluid {
    max-width: 100%;
    --props-image-height: auto;
    --props-scale-mode: scale-to-fit;
}

.img-thumbnail {
    padding: 4px;
    background-color: var(--rs-body-bg);
    border-width: var(--rs-border-width);
    border-color: var(--rs-border-color);
    border-radius: var(--rs-border-radius-1);
    max-width: 100%;
    --props-image-height: auto;
    --props-scale-mode: scale-to-fit;
}

.hr {
    margin: 16px 0;
    height: 1px;
    max-height: 1px;
    width: 100%;
    min-width: 16px;
    opacity: 0.25;
    align-self: stretch;
}

.vr {
    margin: 0 16px;
    width: 1px;
    max-width: 1px;
    height: 100%;
    min-height: 16px;
    opacity: 0.25;
    background-color: var(--rs-body-color);
}

.h1>.rule, .h2>.rule, .h3>.rule, .h4>.rule, .h5>.rule, .h6>.rule, .p>.rule {
    background-color: var(--rs-heading-color);
}