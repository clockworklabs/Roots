/* --- Visibility - */
.visible {
    visibility: visible !important;
}
.invisible {
    visibility: hidden !important;
}



/* --- Opacity - */
.opacity-0 {
    opacity: 0;
}
.opacity-25 {
    opacity: 0.25;
}
.opacity-50 {
    opacity: 0.5;
}
.opacity-75 {
    opacity: 0.75;
}
.opacity-100 {
    opacity: 1;
}

/* --- Overflow - */
.overflow-hidden {
    overflow: hidden;
}
.overflow-visible {
    overflow: visible;
}

/* --- Position - */
.position-relative {
    position: relative;
}
.position-absolute {
    position: absolute;
}

/* --- Arrange  Elements - */
.top-0 {
    top: 0;
}
.top-50 {
    top: 50%;
}
.top-100 {
    top: 100%;
}
/* end */.right-0 {
    right: 0;
}
/* end */.right-50 {
    right: 50%;
}
/* end */.right-100 {
    right: 100%;
}
.bottom-0 {
    bottom: 0;
}
.bottom-50 {
    bottom: 50%;
}
.bottom-100 {
    bottom: 100%;
}
/* start */.left-0 {
    left: 0;
}
/* start */.left-50 {
    left: 50%;
}
/* start */.left-100 {
    left: 100%;
}
.translate-middle {
    translate: -50% -50% 0;
}
.translate-x {
    translate: -50% 0 0;
}
.translate-y {
    translate: 0 -50% 0;
}

/* --- Sizing - */
.w-0 {
    width: 0;
}
.w-25 {
    width: 25%;
}
.w-50 {
    width: 50%;
}
.w-75 {
    width: 75%;
}
.w-100 {
    width: 100%;
}
.w-auto {
    width: auto;
}
.mw-100 {
    max-width: 100%;
}
.h-0 {
    height: 0;
}
.h-25 {
    height: 25%;
}
.h-50 {
    height: 50%;
}
.h-75 {
    height: 75%;
}
.h-100 {
    height: 100%;
}
.h-auto {
    height: auto;
}
.mh-100 {
